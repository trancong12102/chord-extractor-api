# Production env for docker-compose.prod.yml
# Copy to .env.prod and fill in real values. NEVER commit .env.prod.

# ---------- Cloudflare Tunnel ----------
# Token from Cloudflare Zero Trust → Networks → Tunnels → <your tunnel>.
# Route a Public Hostname to http://api:8000 in the tunnel config.
TUNNEL_TOKEN=<cloudflare-tunnel-token>
